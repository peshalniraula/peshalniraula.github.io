---
const experiences = [
  {
    title: 'Mid-Level Full Stack Developer',
    company: 'Corbig Technology Pvt. Ltd.',
    period: 'January 2025 – Present',
    badge: 'Present',
    badgeClass: 'from-green-500 to-emerald-500',
    description: 'Leading full-stack development projects, mentoring junior developers, and contributing to architectural decisions while delivering scalable solutions.',
  },
  {
    title: 'Associate Full Stack Developer',
    company: 'Corbig Technology Pvt. Ltd.',
    period: 'July 2022 – December 2024',
    badge: '2.5 years',
    badgeClass: 'from-blue-500 to-blue-600',
    description: 'Developed and maintained web applications, collaborated with cross-functional teams, implemented new features, and participated in code reviews to ensure code quality.',
  },
  {
    title: 'Web Developer Intern',
    company: 'Blue Fox Pvt. Ltd.',
    period: 'August 2020 – November 2020',
    badge: '3 months',
    badgeClass: 'from-purple-500 to-purple-600',
    description: 'Gained foundational knowledge in web development technologies including HTML, CSS, and JavaScript while building responsive websites.',
  },
];
---

<section id="experience" class="relative px-6 py-32">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4 inline-block relative">
        Work Experience
        <div class="absolute -bottom-2 left-0 w-full h-1 bg-gradient-to-r from-blue-500 via-purple-500 to-blue-500 rounded-full animate-gradient-x"></div>
      </h2>
    </div>

    <div class="space-y-12 relative">
      <!-- Timeline line -->
      <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gradient-to-b from-blue-500 via-purple-500 to-blue-500"></div>

      {experiences.map((exp) => (
        <div class="relative pl-16 group">
          <div class="absolute left-4 top-6 w-5 h-5 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full border-4 border-slate-900 group-hover:scale-125 group-hover:shadow-lg group-hover:shadow-blue-500/50 transition-all duration-300"></div>
          <div class="bg-gradient-to-br from-slate-700/80 to-slate-800/80 rounded-2xl p-8 backdrop-blur-xl border border-slate-600/50 hover:border-blue-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-500/10 hover:-translate-y-2 cursor-pointer group-hover:from-blue-900/20 group-hover:to-purple-900/20">
            <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
              <div>
                <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-blue-400 transition-colors">{exp.title}</h3>
                <p class="text-blue-400 font-semibold text-lg flex items-center gap-2">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                  {exp.company}
                </p>
              </div>
              <span class={`px-4 py-2 bg-gradient-to-r ${exp.badgeClass} text-white text-sm font-bold rounded-full shadow-lg hover:shadow-xl hover:scale-110 transition-all`}>
                {exp.badge}
              </span>
            </div>
            <p class="text-slate-400 mb-4 flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {exp.period}
            </p>
            <p class="text-slate-300 leading-relaxed">{exp.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
