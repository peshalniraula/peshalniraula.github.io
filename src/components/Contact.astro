---
---

<section id="contact" class="relative px-6 py-32 bg-slate-800/50">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4 inline-block relative">
        Get In Touch
        <div class="absolute -bottom-2 left-0 w-full h-1 bg-gradient-to-r from-blue-500 via-purple-500 to-blue-500 rounded-full animate-gradient-x"></div>
      </h2>
      <p class="text-lg text-slate-300 mt-6 max-w-2xl mx-auto">
        I'm currently open to new opportunities and collaborations. Feel free to reach out!
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      <!-- Email -->
      <a
        href="mailto:peshalniraula1999@gmail.com"
        class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-slate-700/80 to-slate-800/80 p-6 backdrop-blur-xl border border-slate-600/50 hover:border-blue-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-500/10 hover:-translate-y-2"
      >
        <div class="absolute inset-0 bg-gradient-to-r from-blue-500/5 to-purple-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative flex flex-col items-center gap-4 text-center">
          <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center flex-shrink-0 shadow-lg group-hover:scale-110 group-hover:shadow-blue-500/50 transition-all duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">Email</h3>
            <p class="text-blue-400 text-sm hover:text-blue-300 transition-colors break-all">peshalniraula1999@gmail.com</p>
          </div>
        </div>
      </a>

      <!-- Phone -->
      <a
        href="tel:+9779763748702"
        class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-slate-700/80 to-slate-800/80 p-6 backdrop-blur-xl border border-slate-600/50 hover:border-purple-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-purple-500/10 hover:-translate-y-2"
      >
        <div class="absolute inset-0 bg-gradient-to-r from-purple-500/5 to-blue-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative flex flex-col items-center gap-4 text-center">
          <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl flex items-center justify-center flex-shrink-0 shadow-lg group-hover:scale-110 group-hover:shadow-purple-500/50 transition-all duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1 group-hover:text-purple-400 transition-colors">Phone</h3>
            <p class="text-purple-400 text-sm hover:text-purple-300 transition-colors">+977 9763748702</p>
          </div>
        </div>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/peshalniraula/"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-slate-700/80 to-slate-800/80 p-6 backdrop-blur-xl border border-slate-600/50 hover:border-blue-600/50 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-600/10 hover:-translate-y-2"
      >
        <div class="absolute inset-0 bg-gradient-to-r from-blue-600/5 to-purple-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative flex flex-col items-center gap-4 text-center">
          <div class="w-14 h-14 bg-gradient-to-br from-blue-600 to-blue-700 rounded-xl flex items-center justify-center flex-shrink-0 shadow-lg group-hover:scale-110 group-hover:shadow-blue-600/50 transition-all duration-300">
            <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1 group-hover:text-blue-500 transition-colors">LinkedIn</h3>
            <p class="text-blue-400 text-sm hover:text-blue-300 transition-colors">Connect</p>
          </div>
        </div>
      </a>

      <!-- GitHub -->
      <a
        href="https://github.com/peshalniraula"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-slate-700/80 to-slate-800/80 p-6 backdrop-blur-xl border border-slate-600/50 hover:border-slate-400/50 transition-all duration-500 hover:shadow-2xl hover:shadow-slate-400/10 hover:-translate-y-2"
      >
        <div class="absolute inset-0 bg-gradient-to-r from-slate-500/5 to-purple-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative flex flex-col items-center gap-4 text-center">
          <div class="w-14 h-14 bg-gradient-to-br from-slate-300 to-slate-400 rounded-xl flex items-center justify-center flex-shrink-0 shadow-lg group-hover:scale-110 group-hover:shadow-slate-400/50 transition-all duration-300">
            <svg class="w-7 h-7 text-slate-900" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1 group-hover:text-slate-300 transition-colors">GitHub</h3>
            <p class="text-slate-400 text-sm hover:text-slate-300 transition-colors">Follow</p>
          </div>
        </div>
      </a>
    </div>

    <!-- CTA Button -->
    <div class="text-center">
      <a
        href="mailto:iampeshalniraula@gmail.com"
        class="group relative inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-blue-600 via-purple-600 to-blue-600 hover:from-blue-700 hover:via-purple-700 hover:to-blue-700 text-white font-bold text-lg rounded-2xl transition-all duration-300 shadow-2xl hover:shadow-blue-500/25 hover:-translate-y-1 hover:scale-105 overflow-hidden"
      >
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-shimmer"></div>
        <svg class="w-6 h-6 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
        <span class="relative">Send Me a Message</span>
      </a>
    </div>
  </div>
</section>
