---
---

<div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
  <!-- Layered aura effects -->
  <div class="absolute top-20 left-10 w-72 h-72 bg-blue-500/20 rounded-full blur-3xl animate-pulse"></div>
  <div class="absolute top-40 right-20 w-96 h-96 bg-purple-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s"></div>
  <div class="absolute bottom-20 left-1/3 w-80 h-80 bg-blue-600/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s"></div>

  <!-- Ambient orbs -->
  <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-cyan-400/15 rounded-full blur-3xl animate-float" style="animation-delay: 0.5s"></div>
  <div class="absolute bottom-1/3 right-1/4 w-72 h-72 bg-pink-500/15 rounded-full blur-3xl animate-float" style="animation-delay: 1.5s"></div>
  <div class="absolute top-1/2 right-1/3 w-56 h-56 bg-violet-400/15 rounded-full blur-3xl animate-float" style="animation-delay: 2.5s"></div>

  <!-- Gradient mesh overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-slate-900/30 to-slate-900/60"></div>
</div>
