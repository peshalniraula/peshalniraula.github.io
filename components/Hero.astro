---
---

<!-- Fixed Avatar -->
<div class="fixed top-24 left-6 z-30">
  <div class="relative w-16 h-16">
    <div class="absolute inset-0 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full blur-xl animate-pulse"></div>
    <div class="absolute -inset-2 bg-gradient-to-br from-cyan-400/20 to-purple-500/20 rounded-full blur-2xl animate-pulse" style="animation-delay: 0.5s"></div>
    <div class="relative w-16 h-16 rounded-full bg-gradient-to-br from-blue-500 via-purple-500 to-blue-600 flex items-center justify-center text-white text-2xl font-bold shadow-2xl hover:scale-110 transition-all duration-500 cursor-pointer group">
      <span class="group-hover:animate-bounce">PN</span>
    </div>
    <div class="absolute inset-0 rounded-full border-2 border-blue-500/40 animate-spin shadow-[0_0_10px_rgba(59,130,246,0.3)]" style="animation-duration: 20s"></div>
    <div class="absolute inset-1 rounded-full border-2 border-purple-500/40 animate-spin shadow-[0_0_10px_rgba(139,92,246,0.3)]" style="animation-duration: 15s; animation-direction: reverse"></div>
  </div>
</div>

<section class="relative min-h-screen flex items-center justify-center px-6 py-20 pt-32">
  <div class="max-w-4xl mx-auto text-center hero-content">
    <!-- Name -->
    <div class="relative inline-block mb-6">
      <h1 class="text-5xl md:text-7xl font-bold bg-gradient-to-r from-white via-blue-200 to-purple-200 bg-clip-text text-transparent animate-gradient-x drop-shadow-[0_0_30px_rgba(59,130,246,0.3)]">
        Peshal Niraula
      </h1>
      <div class="absolute -inset-4 bg-gradient-to-r from-blue-500/10 via-purple-500/10 to-blue-500/10 blur-3xl -z-10"></div>
    </div>

    <!-- Title -->
    <div class="relative inline-block mb-8">
      <p class="text-2xl md:text-3xl text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400 font-bold drop-shadow-[0_0_20px_rgba(139,92,246,0.3)]">
        Software Engineer / Full Stack Developer
      </p>
      <div class="absolute -inset-2 bg-gradient-to-r from-purple-500/10 to-blue-500/10 blur-xl -z-10"></div>
    </div>

    <!-- Location -->
    <div class="flex items-center justify-center gap-2 text-slate-300 mb-10">
      <svg class="w-5 h-5 text-blue-400 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span class="hover:text-blue-400 transition-colors cursor-default">Kathmandu, Nepal</span>
    </div>

    <!-- Bio -->
    <p class="text-lg text-slate-300 max-w-2xl mx-auto mb-12 leading-relaxed">
      Software engineer passionate about turning ideas into reality through software engineering, whether working individually or in innovative teams.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap items-center justify-center gap-6 mt-8">
      <a
        href="#contact"
        class="group relative px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-bold rounded-xl transition-all duration-300 shadow-lg hover:shadow-2xl hover:-translate-y-1 hover:scale-105 overflow-hidden"
      >
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-shimmer"></div>
        <span class="relative flex items-center gap-2">
          Get In Touch
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </span>
      </a>
      <a
        href="#experience"
        class="group relative px-8 py-4 bg-transparent border-2 border-blue-500 text-blue-400 hover:bg-blue-500 hover:text-white font-bold rounded-xl transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 hover:scale-105"
      >
        View Experience
      </a>
    </div>
  </div>
</section>

<script>
  // Fade-in on load (replaces the React isLoaded state)
  const hero = document.querySelector('.hero-content') as HTMLElement | null;
  if (hero) {
    hero.style.opacity = '0';
    hero.style.transform = 'translateY(40px)';
    hero.style.transition = 'opacity 1s ease, transform 1s ease';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        hero.style.opacity = '1';
        hero.style.transform = 'translateY(0)';
      });
    });
  }
</script>
